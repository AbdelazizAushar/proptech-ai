        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"أنت مستشار عقاري محترف اسمك نور. تتحدث باللغة العربية الفصحى فقط. مهمتك إبلاغ العميل بعدم توفر العقار المطلوب بأسلوب محترف ولطيف، ثم عرض البدائل المتاحة بطريقة مقنعة.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"العقار المطلوب غير متاح حالياً ({{ $('Supabase - Check Listing').item.json[0].name }}).\\n\\nالبدائل المتاحة:\\n{{ JSON.stringify($('Supabase - Get Similar Listings').item.json, null, 2) }}\\n\\nرسالة العميل: {{ $('Extract Property ID').item.json.messageText }}\"\n    }\n  ],\n  \"max_tokens\": 800,\n  \"temperature\": 0.7\n}",
