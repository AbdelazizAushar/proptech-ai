        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\nconst from = body.from || body.sender || body.phone || '';\nconst type = body.type || 'text';\nconst text = body.text?.body || body.text || body.message || '';\nconst audioUrl = body.audio?.url || body.audioUrl || '';\nconst imageUrl = body.image?.url || body.imageUrl || '';\n\nreturn [{\n  json: {\n    from,\n    type,\n    text,\n    audioUrl,\n    imageUrl,\n    originalPayload: body\n  }\n}];"
      },
