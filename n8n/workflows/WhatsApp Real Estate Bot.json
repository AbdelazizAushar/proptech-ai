    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.GROQ_API_URL }}/openai/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
