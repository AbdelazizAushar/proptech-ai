    {
      "parameters": {
        "jsCode": "const inputItems = $input.all();\nconst first = inputItems[0].json;\n\n// Determine if this came from audio transcription or image description\nlet resolvedText = first.text;\n\nif (first.text !== undefined && first.audioUrl !== undefined) {\n  // This is pass-through from text branch — keep as is\n  resolvedText = first.text;\n} else if (first.text !== undefined && first.imageUrl !== undefined) {\n  resolvedText = first.text;\n}\n\n// If transcription result is present\nif (first.hasOwnProperty('transcript')) {\n  resolvedText = first.transcript;\n}\n\n// If vision result is present\nif (first.choices && first.choices[0]?.message?.content) {\n  resolvedText = first.choices[0].message.content;\n}\n\nreturn [{\n  json: {\n    from: first.from,\n    type: first.type,\n    text: resolvedText,\n    audioUrl: first.audioUrl || '',\n    imageUrl: first.imageUrl || '',\n    originalPayload: first.originalPayload || {}\n  }\n}];"
      },
