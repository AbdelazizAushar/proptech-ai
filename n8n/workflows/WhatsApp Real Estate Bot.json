        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"أنت مستشار عقاري محترف اسمك \\\"نور\\\". تتحدث باللغة العربية الفصحى فقط.\\nمهمتك مساعدة العميل في الحصول على معلومات دقيقة حول العقار واتخاذ قرار الشراء أو الحجز.\\n\\nقواعد المحادثة:\\n- أجب دائماً بالعربية فقط\\n- كن ودوداً ومحترفاً وواثقاً\\n- استخدم المعلومات المتاحة في قاعدة المعرفة للإجابة على الأسئلة\\n- إذا لم تجد المعلومة، قل \\\"سأتحقق من هذا لك\\\"\\n- استخدم تقنيات الإقناع بشكل طبيعي: أبرز المزايا، خلق الإلحاحية بلطف، ربط احتياجات العميل بمميزات العقار\\n- راقب مستوى الاهتمام في المحادثة\\n\\nعند اكتشاف اهتمام جدي بالحجز (عندما يسأل عن موعد المعاينة، أو يقول \\\"أريد الحجز\\\"، أو \\\"كيف أتقدم\\\", أو يُظهر نية واضحة للمضي قدماً):\\n- أضف في نهاية ردك هذا النص بالضبط على سطر منفصل: [INTEREST_DETECTED]\\n\\nمعلومات العقار ستُزوَّد لك في كل رسالة ضمن قسم [معلومات العقار المتاحة].\"\n    },\n    ...{{ JSON.stringify($('Extract Property ID').item.json.conversationMessages.map(m => ({ role: m.role, content: m.content }))) }},\n    {\n      \"role\": \"user\",\n      \"content\": \"{{ $('Extract Property ID').item.json.messageText }}\\n\\n[معلومات العقار المتاحة]\\n{{ $('Supabase - Query Knowledge Base').item.json.map(chunk => chunk.content).join('\\n---\\n') }}\"\n    }\n  ],\n  \"max_tokens\": 1000,\n  \"temperature\": 0.7\n}",
        "options": {}
      },
      "id": "60d19cec-3909-499a-a309-bdd5e08d6bf8",
      "name": "Groq - Generate Consultation Reply",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        4304,
        624
      ]
    },
    {
      "parameters": {
        "jsCode": "// Determine which branch we came from\nlet rawReply = '';\nlet source = 'consultation';\n\ntry {\n  const consultReply = $('Groq - Generate Consultation Reply').item?.json;\n  if (consultReply?.choices?.[0]?.message?.content) {\n    rawReply = consultReply.choices[0].message.content;\n    source = 'consultation';\n  }\n} catch(e) {}\n\ntry {\n  const altReply = $('Groq - Generate Alternatives Reply').item?.json;\n  if (altReply?.choices?.[0]?.message?.content) {\n    rawReply = altReply.choices[0].message.content;\n    source = 'alternatives';\n  }\n} catch(e) {}\n\nconst interestDetected = rawReply.includes('[INTEREST_DETECTED]');\nconst cleanReply = rawReply.replace('[INTEREST_DETECTED]', '').trim();\n\nconst ctx = $('Extract Property ID').item.json;\n\nreturn [{\n  json: {\n    from: ctx.from,\n    messageText: ctx.messageText,\n    userId: ctx.userId,\n    userName: ctx.userName,\n    userPhone: ctx.userPhone,\n    conversationId: ctx.conversationId,\n    conversationMessages: ctx.conversationMessages,\n    propertyId: ctx.propertyId,\n    botReply: cleanReply,\n    interestDetected,\n    source,\n    userRecord: ctx.userRecord\n  }\n}];"
      },
