        "jsCode": "const messageText = $('Merge Media Back').first().json.text || '';\nconst userRecord = $('Supabase - Get or Create User').first().json[0] || {};\nconst conversationArr = $('Supabase - Load Conversation').first().json || [];\nconst conversation = Array.isArray(conversationArr) ? conversationArr[0] : null;\n\n// Extract #PROPERTY_ID pattern\nconst match = messageText.match(/#([\\w-]+)/);\nconst propertyId = match ? match[1] : null;\n\n// Build context\nconst messages = conversation ? (conversation.messages || []) : [];\nconst conversationId = conversation ? conversation.id : null;\nconst listingId = conversation ? conversation.listing_id : null;\n\nreturn [{\n  json: {\n    from: $('Merge Media Back').first().json.from,\n    messageText,\n    type: $('Merge Media Back').first().json.type,\n    propertyId: propertyId || listingId,\n    isNewPropertyRequest: !!propertyId,\n    userId: userRecord.id,\n    userName: userRecord.name || null,\n    userPhone: userRecord.phone || null,\n    conversationId,\n    conversationMessages: messages,\n    userRecord\n  }\n}];"
