      "parameters": {
        "jsCode": "const inputItems = $input.all();\nconst first = inputItems[0].json;\n\nlet originalText = first.text || \"\"; \nlet resolvedText = originalText;\n\nif (first.hasOwnProperty('transcript') && first.transcript) {\n  resolvedText = first.transcript;\n}\n\nif (first.choices && first.choices[0]?.message?.content) {\n  let imageDescription = first.choices[0].message.content.trim();\n  \n  if (originalText && originalText.trim() !== \"\") {\n    resolvedText = `${originalText}\\n🌟 (ملاحظة للنظام: العميل يبحث عن عقار يطابق هذا الوصف البصري: ${imageDescription})`;\n  } else {\n    resolvedText = imageDescription;\n  }\n}\n\nreturn [{\n  json:\n  { from: first.from,\n    type: first.type,\n    text: resolvedText,\n    audioUrl: first.audioUrl || '',\n    imageUrl: first.imageUrl || '',\n    originalPayload: first.originalPayload || {} \n  } \n}];"
      },
