    {
      "parameters": {
        "jsCode": "const { userName, userPhone, conversationMessages, messageText, from, userId, conversationId, propertyId, botReply } = $json;\n\n// Determine what data collection stage we're at\nlet collectionStage = 'complete';\n\nif (!userName) {\n  collectionStage = 'awaiting_name';\n} else if (!userPhone) {\n  // Check if last bot message was asking for phone and user just replied\n  const lastBotMsg = [...conversationMessages].reverse().find(m => m.role === 'assistant');\n  if (lastBotMsg && lastBotMsg.content && lastBotMsg.content.includes('رقم هاتفك')) {\n    // User's current message should be the phone number\n    collectionStage = 'save_phone';\n  } else {\n    collectionStage = 'awaiting_phone';\n  }\n} else {\n  // Check if we have appointment\n  const lastBotMsg = [...conversationMessages].reverse().find(m => m.role === 'assistant');\n  if (lastBotMsg && lastBotMsg.content && lastBotMsg.content.includes('موعد المعاينة')) {\n    collectionStage = 'save_appointment';\n  } else if (!conversationMessages.some(m => m.role === 'assistant' && m.content.includes('موعد المعاينة'))) {\n    collectionStage = 'awaiting_appointment';\n  } else {\n    collectionStage = 'complete';\n  }\n}\n\n// Parse appointment from message if saving\nlet appointmentDate = null;\nlet appointmentTime = null;\nif (collectionStage === 'save_appointment') {\n  // Simple regex to extract date patterns from Arabic text\n  const dateMatch = messageText.match(/(\\d{1,2}[\\/-]\\d{1,2}[\\/-]\\d{2,4})/);\n  const timeMatch = messageText.match(/(\\d{1,2}:\\d{2}|\\d{1,2}\\s*[صمpm]+)/);\n  appointmentDate = dateMatch ? dateMatch[1] : new Date().toISOString().split('T')[0];\n  appointmentTime = timeMatch ? timeMatch[1] : '10:00';\n}\n\n// If saving name, extract from message\nlet extractedName = userName;\nif (collectionStage === 'awaiting_name' || (collectionStage !== 'complete' && !userName)) {\n  const lastBotMsg = [...conversationMessages].reverse().find(m => m.role === 'assistant');\n  if (lastBotMsg && lastBotMsg.content && lastBotMsg.content.includes('اسمك')) {\n    extractedName = messageText.trim();\n    collectionStage = 'save_name';\n  }\n}\n\nlet extractedPhone = userPhone;\nif (collectionStage === 'save_phone') {\n  extractedPhone = messageText.replace(/[^\\d+]/g, '');\n}\n\nreturn [{\n  json: {\n    from,\n    userId,\n    conversationId,\n    propertyId,\n    botReply,\n    collectionStage,\n    userName: extractedName,\n    userPhone: extractedPhone,\n    appointmentDate,\n    appointmentTime,\n    conversationMessages,\n    messageText\n  }\n}];"
      },
